# 이 파일을 .env 로 복사한 뒤 실제 값을 채워주세요. (.env는 git에 커밋되지 않습니다)

# Google AI Studio에서 발급받은 Gemini API 키
GEMINI_API_KEY=

# 결과를 저장할 구글 시트의 ID (URL의 /d/ 와 /edit 사이 값)
GOOGLE_SHEETS_ID=

# 이미지를 저장할 구글 드라이브 폴더의 ID
GOOGLE_DRIVE_FOLDER_ID=

# apps_script/이미지업로드.gs 를 배포한 웹앱 URL
DRIVE_UPLOAD_WEBAPP_URL=

# apps_script/이미지업로드.gs 의 BIMIL_KEY와 동일한 값
DRIVE_UPLOAD_SECRET=
